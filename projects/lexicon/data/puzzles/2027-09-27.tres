[gd_resource type="Resource" script_class="PuzzleData" load_steps=9 format=3]

[ext_resource type="Script" path="res://src/core/puzzle_data.gd" id="1_puzzledata"]
[ext_resource type="Script" path="res://src/core/group_data.gd" id="2_groupdata"]
[ext_resource type="Script" path="res://src/core/reveal_config.gd" id="3_revealconfig"]

[sub_resource type="Resource" id="Resource_defaultcfg"]
script = ExtResource("3_revealconfig")
reveal_steps = Array[int]([1, 2, 2])
reveal_order = "left_to_right"
stagger_delay = 0.15

[sub_resource type="Resource" id="Resource_group0"]
script = ExtResource("2_groupdata")
category_name = "APPRECIATION"
words = Array[String](["CREDIT", "PRAISE", "RECOGNITION", "THANKS"])
anchor_word = "CREDIT"

[sub_resource type="Resource" id="Resource_group1"]
script = ExtResource("2_groupdata")
category_name = "FRAUDSTER"
words = Array[String](["CHEAT", "CON", "FAKE", "QUACK"])
anchor_word = "CHEAT"

[sub_resource type="Resource" id="Resource_group2"]
script = ExtResource("2_groupdata")
category_name = "EAT VORACIOUSLY"
words = Array[String](["BOLT", "DOWN", "GOBBLE", "SCARF"])
anchor_word = "BOLT"

[sub_resource type="Resource" id="Resource_group3"]
script = ExtResource("2_groupdata")
category_name = "___ TUESDAY"
words = Array[String](["FAT", "GIVING", "SUPER", "TACO"])
anchor_word = "FAT"

[resource]
script = ExtResource("1_puzzledata")
puzzle_id = "2027-09-27"
title = "Puzzle #536"
groups = Array[ExtResource("2_groupdata")]([SubResource("Resource_group0"), SubResource("Resource_group1"), SubResource("Resource_group2"), SubResource("Resource_group3")])
default_reveal_config = SubResource("Resource_defaultcfg")
