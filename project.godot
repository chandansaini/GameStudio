; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="LEXICON"
run/main_scene="res://src/scenes/main_menu.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/run/main_scene="res://src/scenes/main_menu.tscn"

[autoload]

GSM="*res://src/core/game_state_manager.gd"
PuzzleLibrary="*res://src/core/puzzle_library.gd"
SceneManager="*res://src/core/scene_manager.gd"
SavePersist="*res://src/core/save_persist_system.gd"
DailyLock="*res://src/core/daily_lock_system.gd"
AudioSys="*res://src/core/audio_system.gd"
UIScale="*res://src/core/ui_scale.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=900
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
